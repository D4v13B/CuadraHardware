<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="Cuadra POS Agent" Manufacturer="Cuadra ERP"
           Version="$(var.ProductVersion)"
           UpgradeCode="2D23BB1A-BC91-49CE-923E-79D58C842821"
           Language="1034" Scope="perMachine" InstallerVersion="500">
    <SummaryInformation Description="Servicio local de integración de hardware para Cuadra POS"
                        Manufacturer="Cuadra ERP" />
    <MajorUpgrade DowngradeErrorMessage="Ya existe una versión más reciente de Cuadra POS Agent." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <Icon Id="CuadraAgentIcon" SourceFile="..\assets\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="CuadraAgentIcon" />
    <Property Id="ARPHELPLINK" Value="https://cuadraerp.com/soporte" />
    <Property Id="ARPURLINFOABOUT" Value="https://cuadraerp.com" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Cuadra POS Agent" />
    </StandardDirectory>
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="PROGRAMDATA_VENDOR" Name="Cuadra ERP">
        <Directory Id="PROGRAMDATA_FOLDER" Name="Cuadra POS Agent">
          <Directory Id="LOGS_FOLDER" Name="logs" />
          <Directory Id="CERTS_FOLDER" Name="certs" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Cuadra POS Agent" Level="1">
      <ComponentRef Id="AgentExecutableComponent" />
      <ComponentRef Id="ConfigurationComponent" />
      <ComponentRef Id="LogsDirectoryComponent" />
      <ComponentRef Id="CertsDirectoryComponent" />
    </Feature>

    <Component Id="AgentExecutableComponent" Directory="INSTALLFOLDER" Bitness="always64" Guid="*">
      <File Id="AgentExecutable" Source="..\target\x86_64-pc-windows-msvc\release\cuadra-pos-agent.exe" KeyPath="yes" />
      <ServiceInstall Id="CuadraPosAgentServiceInstall" Name="CuadraPosAgent"
                      DisplayName="Cuadra POS Agent"
                      Description="Agente local para impresoras térmicas, gavetas y dispositivos POS."
                      Type="ownProcess" Start="auto" ErrorControl="normal"
                      Account="LocalSystem" Arguments="--service" />
      <ServiceControl Id="CuadraPosAgentServiceControl" Name="CuadraPosAgent"
                      Start="install" Stop="both" Remove="uninstall" Wait="yes" />
      <util:ServiceConfig FirstFailureActionType="restart" SecondFailureActionType="restart"
                          ThirdFailureActionType="restart" RestartServiceDelayInSeconds="5"
                          ResetPeriodInDays="1" />
    </Component>

    <Component Id="ConfigurationComponent" Directory="PROGRAMDATA_FOLDER" Guid="*">
      <File Id="DefaultConfiguration" Source="..\config\config.example.json"
            Name="config.json" KeyPath="yes" NeverOverwrite="yes" />
      <CreateFolder>
        <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        <util:PermissionEx User="Administrators" GenericAll="yes" />
      </CreateFolder>
    </Component>
    <Component Id="LogsDirectoryComponent" Directory="LOGS_FOLDER" Guid="*">
      <CreateFolder>
        <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        <util:PermissionEx User="Administrators" GenericAll="yes" />
      </CreateFolder>
    </Component>
    <Component Id="CertsDirectoryComponent" Directory="CERTS_FOLDER" Guid="*">
      <CreateFolder>
        <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        <util:PermissionEx User="Administrators" GenericAll="yes" />
      </CreateFolder>
    </Component>

    <CustomAction Id="PrepareCertificates" FileRef="AgentExecutable" ExeCommand="--install-ca"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <InstallExecuteSequence>
      <Custom Action="PrepareCertificates" After="InstallFiles" Condition="NOT REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="..\assets\license.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="..\assets\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="..\assets\dialog.bmp" />
  </Package>
</Wix>
